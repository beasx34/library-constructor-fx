# Скопируйте этот файл в .env и при желании поменяйте значения.
# .env находится в .gitignore и не попадает в git.

# === База данных ===
MYSQL_ROOT_PASSWORD=1423
MYSQL_DATABASE=test
MYSQL_USER=user
MYSQL_PASSWORD=1423

# === Бэкенд ===
# Любая случайная строка >= 32 символов. Сгенерировать: `openssl rand -hex 32`
SECRET_KEY=dev_secret_change_me_in_production_xxxxxxxxxxxxxxxx

# === Cloudflare Tunnel (только для docker-compose.tunnel.yaml) ===
# Получить: Cloudflare Zero Trust Dashboard -> Networks -> Tunnels -> Create a tunnel
CLOUDFLARE_TUNNEL_TOKEN=

# === Let's Encrypt (только для docker-compose.yaml на VPS) ===
LETSENCRYPT_EMAIL=admin@rapidstream.ru
